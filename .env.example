# Embedding
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5

# Vector DB
KB_SOURCE_DIR=kb_sources
FAISS_INDEX_PATH=vector_db/faiss.index
CHUNKS_PATH=vector_db/chunks.json
KB_MANIFEST_PATH=vector_db/source_manifest.json
CHUNK_SIZE=500
CHUNK_OVERLAP=100
FORCE_REBUILD_KB=false

# Retrieval
TOP_K=3
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-base

# LLM (OpenAI-compatible endpoint; optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=qwen2.5:7b-instruct
